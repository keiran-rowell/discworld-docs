{% if page.collection == "field-guide" %}
<!-- Hidden Logic Engine (Safely executing at the bottom of the page) -->
<script type="text/javascript">
  (function() {
    function buildSidebarTOC() {
      var headings = document.querySelectorAll(".page__content h3");
      var tocContainer = document.getElementById("custom-side-toc");
      var tocList = document.getElementById("toc-js-target");
      
      if (!headings || !tocContainer || !tocList) return;
      
      tocList.innerHTML = "";
      
      if (headings.length > 0) {
        headings.forEach(function(heading) {
          if (heading.id) {
            var li = document.createElement("li");
            var a = document.createElement("a");
            
            a.href = "#" + heading.id;
            a.textContent = heading.innerText || heading.textContent;
            
            li.appendChild(a);
            tocList.appendChild(li);
          }
        });
        
        tocContainer.style.display = "block";
      }
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", buildSidebarTOC);
    } else {
      buildSidebarTOC();
    }
  })();
</script>
{% endif %}
